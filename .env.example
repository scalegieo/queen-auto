# Frazer DMS API Integration
# Insert your Frazer API key securely — never commit real keys
FRAZER_API_KEY=
FRAZER_API_URL=https://api.frazer.example.com/v1

# Optional: dealer ID if your Frazer partner requires it
FRAZER_DEALER_ID=

# Cron secret for daily inventory sync (Vercel Cron / external scheduler)
CRON_SECRET=

# Public site URL (used for SEO canonicals & sitemap)
NEXT_PUBLIC_SITE_URL=https://www.queenautosales.com

# Optional: unlock smarter Queen AI replies (falls back to built-in sales logic)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: live Google Reviews + rating (Place Details API)
GOOGLE_PLACES_API_KEY=

# Dealership contact (override defaults in code if needed)
NEXT_PUBLIC_PHONE=7209029561
NEXT_PUBLIC_PHONE_DISPLAY=(720) 902-9561
NEXT_PUBLIC_PHONE_ES=3034841543
NEXT_PUBLIC_PHONE_ES_DISPLAY=(303) 484-1543
